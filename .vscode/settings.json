{
  "github.copilot.enable": {
    "*": true,
    "plaintext": true,
    "markdown": true
  },
  "github.copilot.advanced": {
    "debug.overrideCachePath": "",
    "debug.testOverrideProxyUrl": "",
    "debug.useEliteNoxusToken": true
  },
  "[copilot]": {
    "editor.defaultFormatter": "github.copilot",
    "editor.formatOnSave": true
  },
  "copilot.enable": {
    "csharp": true,
    "python": true,
    "javascript": true,
    "typescript": true,
    "jsx": true,
    "tsx": true,
    "vue": true,
    "svelte": true,
    "json": true,
    "yaml": true,
    "markdown": true,
    "plaintext": true
  },
  "editor.inlineChat.enabled": true,
  "chat.commandCenter.enabled": true,
  "github.copilot.chat.enabled": true,
  "github.copilot.chat.agentSelection": "always",
  "workbench.editorAssociations": {
    "*.copilot": "default"
  },
  "extensions.ignoreRecommendations": false,
  "[markdown]": {
    "editor.wordWrap": "on"
  },
  "editor.stickyScroll.enabled": true
}
